# Supabase Configuration
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# AI Services
GEMINI_API_KEY=your-gemini-api-key

# Email (Resend)
RESEND_API_KEY=your-resend-api-key
RESEND_NEWSLETTER_AUDIENCE_ID=your-audience-id

# Discord notifications
DISCORD_SIGNUP_WEBHOOK_URL=https://discord.com/api/webhooks/...
DISCORD_PURCHASE_WEBHOOK_URL=https://discord.com/api/webhooks/...

# PayPlus Payments
PAYPLUS_API_KEY=your-api-key
PAYPLUS_SECRET_KEY=your-secret-key
PAYPLUS_PAGE_UID=your-page-uid

# Admin
ADMIN_EMAILS=admin@example.com,admin2@example.com

# Cron Security
CRON_SECRET=your-random-secret-string

# Optional: Set automatically by Next.js
# NODE_ENV=development

# Google Ads API (internal admin/reporting only)
GOOGLE_ADS_DEVELOPER_TOKEN=your-developer-token
GOOGLE_ADS_CLIENT_ID=your-oauth-client-id
GOOGLE_ADS_CLIENT_SECRET=your-oauth-client-secret
GOOGLE_ADS_REFRESH_TOKEN=your-oauth-refresh-token-with-adwords-scope
GOOGLE_ADS_LOGIN_CUSTOMER_ID=7504938788
GOOGLE_ADS_CUSTOMER_ID=your-client-customer-id-without-hyphens
GOOGLE_ADS_LOGIN_CUSTOMER_ID_MODE=auto
